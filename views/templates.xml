<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="onboarding_template" name="Charity Onboarding Form">
        <t t_call="website.layout">
            <div id="wrap" class="js_onboarding_form">
                <section class="s_title parallax s_parallax_is_fixed bg-900 py-5" data-scroll-background-ratio="1">
                    <span class="s_parallax_bg oe_img_bg" style="background-image: url('/website/static/src/img/snippets_demo/s_parallax.jpg'); background-position: 50% 0;"/>
                    <div class="container">
                        <h1 class="text-center text-white">انضم إلينا في جمعية غادر 🌟</h1>
                    </div>
                </section>

                <section class="s_text_block py-5">
                    <div class="container">
                        <div class="row justify-content-center">
                            <div class="col-lg-8">
                                <div class="card border-0 shadow-lg">
                                    <div class="card-body p-5">
                                        <p class="lead text-center mb-5 text-muted">
                                            نحن هنا لتمكينك. يرجى تزويدنا ببياناتك لنرسم معك مسارك المهني القادم.
                                        </p>
                                        
                                        <form action="/charity/onboarding/submit" method="post" class="container-fluid">
                                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                            
                                            <div class="row">
                                                <div class="col-md-6 mb-4">
                                                    <label class="form-label fw-bold">الاسم الكامل</label>
                                                    <input type="text" name="name" class="form-control form-control-lg" placeholder="سلطان السالمي" required="1"/>
                                                </div>
                                                <div class="col-md-6 mb-4">
                                                    <label class="form-label fw-bold">البريد الإلكتروني</label>
                                                    <input type="email" name="email" class="form-control form-control-lg" placeholder="example@gader.sa" required="1"/>
                                                </div>

                                                <div class="col-md-6 mb-4">
                                                    <label class="form-label fw-bold">تاريخ الميلاد</label>
                                                    <input type="date" name="birth_date" class="form-control form-control-lg" required="1"/>
                                                </div>
                                                <div class="col-md-6 mb-4">
                                                    <label class="form-label fw-bold">حالة المتدرب</label>
                                                    <select name="trainee_status" class="form-select form-select-lg" required="1">
                                                        <option value="">اختر الحالة...</option>
                                                        <option value="job_seeker">باحث عن عمل</option>
                                                        <option value="graduate">خريج</option>
                                                        <option value="student">طالب</option>
                                                        <option value="employee">موظف</option>
                                                    </select>
                                                </div>

                                                <div class="col-12 mb-4">
                                                    <label class="form-label fw-bold">المسار المراد تطويره</label>
                                                    <select id="path_select" name="assigned_path" class="form-select form-select-lg border-primary" required="1" onchange="updateSkills()">
                                                        <option value="">اختر المسار...</option>
                                                        <option value="office">مكتبي</option>
                                                        <option value="technical">فني</option>
                                                        <option value="craft">حرفي</option>
                                                    </select>
                                                </div>

                                                <div id="skills_section" class="col-12 mb-5 d-none">
                                                    <div class="p-4 border rounded shadow-sm" style="background-color: #fcfcfc;">
                                                        <label class="form-label fw-bold d-block mb-3 border-bottom pb-2">اختر المهارات المتاحة في هذا المسار:</label>
                                                        
                                                        <div id="technical_skills" class="row skill-group d-none">
                                                            <div class="col-6 mb-2"><div class="form-check form-switch"><input class="form-check-input" type="checkbox" name="skills" value="التسويق الالكتروني"/><label class="form-check-label">التسويق الالكتروني</label></div></div>
                                                            <div class="col-6 mb-2"><div class="form-check form-switch"><input class="form-check-input" type="checkbox" name="skills" value="التصميم الجرافيك"/><label class="form-check-label">التصميم الجرافيك</label></div></div>
                                                            <div class="col-6 mb-2"><div class="form-check form-switch"><input class="form-check-input" type="checkbox" name="skills" value="تصميم المؤثرات"/><label class="form-check-label">تصميم المؤثرات</label></div></div>
                                                            <div class="col-6 mb-2"><div class="form-check form-switch"><input class="form-check-input" type="checkbox" name="skills" value="التصوير الفوتغرافي"/><label class="form-check-label">التصوير الفوتغرافي</label></div></div>
                                                        </div>

                                                        <div id="craft_skills" class="row skill-group d-none">
                                                            <div class="col-6 mb-2"><div class="form-check form-switch"><input class="form-check-input" type="checkbox" name="skills" value="الخط العربي"/><label class="form-check-label">الخط العربي</label></div></div>
                                                            <div class="col-6 mb-2"><div class="form-check form-switch"><input class="form-check-input" type="checkbox" name="skills" value="صناعة العطور"/><label class="form-check-label">صناعة العطور</label></div></div>
                                                            <div class="col-6 mb-2"><div class="form-check form-switch"><input class="form-check-input" type="checkbox" name="skills" value="صيانة الاجهزه"/><label class="form-check-label">صيانة الاجهزه</label></div></div>
                                                            <div class="col-6 mb-2"><div class="form-check form-switch"><input class="form-check-input" type="checkbox" name="skills" value="الصيانة المنزلية"/><label class="form-check-label">الصيانة المنزلية</label></div></div>
                                                        </div>
                                                    </div>
                                                </div>

                                                <div class="col-12">
                                                    <button type="submit" class="btn btn-primary btn-lg w-100 fw-bold shadow-sm">
                                                        إرسال طلب الانضمام
                                                    </button>
                                                </div>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>
            </div>

            <script>
                function updateSkills() {
                    const path = document.getElementById('path_select').value;
                    const section = document.getElementById('skills_section');
                    const tech = document.getElementById('technical_skills');
                    const craft = document.getElementById('craft_skills');

                    section.classList.add('d-none');
                    tech.classList.add('d-none');
                    craft.classList.add('d-none');

                    if (path === 'technical') {
                        section.classList.remove('d-none');
                        tech.classList.remove('d-none');
                    } else if (path === 'craft') {
                        section.classList.remove('d-none');
                        craft.classList.remove('d-none');
                    }
                }
            </script>
        </t>
    </template>
</odoo>
