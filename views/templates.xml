<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="onboarding_template" name="Charity Onboarding Form">
        <t t_call="website.layout">
            <div id="wrap" class="oe_structure oe_empty">
                <section class="s_text_block py-5 bg-100">
                    <div class="container">
                        <div class="row justify-content-center">
                            <div class="col-lg-8 card shadow-sm border-0 p-4 p-md-5 bg-white">
                                <h2 class="text-center mb-4 mt-2">انضم إلينا في جمعية غادر 🌟</h2>
                                <p class="text-center text-muted mb-5">نحن هنا لتمكينك. يرجى تزويدنا بالبيانات الإضافية لنرسم معك مسارك المهني.</p>
                                
                                <form action="/charity/onboarding/submit" method="post" class="container-fluid">
                                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                    
                                    <div class="row g-4">
                                        <t t_if="request.website.is_public_user()">
                                            <div class="col-md-6">
                                                <label class="form-label fw-bold">الاسم الكامل</label>
                                                <input type="text" name="name" class="form-control" required="1" placeholder="سلطان السالمي"/>
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label fw-bold">البريد الإلكتروني</label>
                                                <input type="email" name="email" class="form-control" required="1" placeholder="example@gader.sa"/>
                                            </div>
                                        </t>

                                        <div class="col-md-6">
                                            <label class="form-label fw-bold">تاريخ الميلاد</label>
                                            <input type="date" name="birth_date" class="form-control" required="1"/>
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label fw-bold">حالة المتدرب</label>
                                            <select name="trainee_status" class="form-select" required="1">
                                                <option value="">اختر الحالة...</option>
                                                <option value="job_seeker">باحث عن عمل</option>
                                                <option value="graduate">خريج</option>
                                                <option value="student">طالب</option>
                                                <option value="employee">موظف</option>
                                            </select>
                                        </div>

                                        <div class="col-12">
                                            <label class="form-label fw-bold text-primary">المسار المراد تطويره</label>
                                            <select id="path_select" name="assigned_path" class="form-select border-primary bg-light" required="1" onchange="updateSkills()">
                                                <option value="">اختر المسار الذي يمثلك...</option>
                                                <option value="office">مكتبي</option>
                                                <option value="technical">فني</option>
                                                <option value="craft">حرفي</option>
                                            </select>
                                        </div>

                                        <div id="skills_section" class="col-12 d-none">
                                            <div class="card bg-light border-0">
                                                <div class="card-body">
                                                    <label class="form-label fw-bold mb-3">اختر المهارات المتاحة في هذا المسار:</label>
                                                    
                                                    <div id="technical_skills" class="row skill-group d-none">
                                                        <div class="col-sm-6 mb-2"><div class="form-check"><input class="form-check-input" type="checkbox" name="skills" value="التسويق الالكتروني"/><label class="form-check-label">التسويق الالكتروني</label></div></div>
                                                        <div class="col-sm-6 mb-2"><div class="form-check"><input class="form-check-input" type="checkbox" name="skills" value="التصميم الجرافيك"/><label class="form-check-label">التصميم الجرافيك</label></div></div>
                                                        <div class="col-sm-6 mb-2"><div class="form-check"><input class="form-check-input" type="checkbox" name="skills" value="تصميم المؤثرات"/><label class="form-check-label">تصميم المؤثرات</label></div></div>
                                                        <div class="col-sm-6 mb-2"><div class="form-check"><input class="form-check-input" type="checkbox" name="skills" value="التصوير الفوتغرافي"/><label class="form-check-label">التصوير الفوتغرافي</label></div></div>
                                                    </div>

                                                    <div id="craft_skills" class="row skill-group d-none">
                                                        <div class="col-sm-6 mb-2"><div class="form-check"><input class="form-check-input" type="checkbox" name="skills" value="الخط العربي"/><label class="form-check-label">الخط العربي</label></div></div>
                                                        <div class="col-sm-6 mb-2"><div class="form-check"><input class="form-check-input" type="checkbox" name="skills" value="صناعة العطور"/><label class="form-check-label">صناعة العطور</label></div></div>
                                                        <div class="col-sm-6 mb-2"><div class="form-check"><input class="form-check-input" type="checkbox" name="skills" value="صيانة الاجهزه"/><label class="form-check-label">صيانة الاجهزه</label></div></div>
                                                        <div class="col-sm-6 mb-2"><div class="form-check"><input class="form-check-input" type="checkbox" name="skills" value="الصيانة المنزلية"/><label class="form-check-label">الصيانة المنزلية</label></div></div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="col-12 mt-4">
                                            <button type="submit" class="btn btn-primary btn-lg w-100 fw-bold shadow-sm" style="background: #006666; border: none;">إرسال طلب الانضمام</button>
                                        </div>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                </section>
            </div>

            <script>
                function updateSkills() {
                    const path = document.getElementById('path_select').value;
                    const section = document.getElementById('skills_section');
                    const tech = document.getElementById('technical_skills');
                    const craft = document.getElementById('craft_skills');

                    section.classList.add('d-none');
                    tech.classList.add('d-none');
                    craft.classList.add('d-none');

                    if (path === 'technical') {
                        section.classList.remove('d-none');
                        tech.classList.remove('d-none');
                    } else if (path === 'craft') {
                        section.classList.remove('d-none');
                        craft.classList.remove('d-none');
                    }
                }
            </script>
        </t>
    </template>
</odoo>
