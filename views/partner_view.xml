<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_partner_form_inherit_charity" model="ir.ui.view">
        <field name="name">res.partner.form.charity</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Charity Info">
                    <group>
                        <field name="birth_date"/>
                        <field name="onboarding_status"/>
                        <field name="assigned_path"/>
                        <field name="selected_skills"/>
                        <field name="is_beneficiary"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
